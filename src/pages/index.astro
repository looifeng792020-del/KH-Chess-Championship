---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KH Chess Championship</title>

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />

    <style>
      :root {
        --bg: #050505;
        --panel: rgba(255, 255, 255, 0.055);
        --panel-soft: rgba(255, 255, 255, 0.025);
        --line: rgba(255, 255, 255, 0.1);
        --text: #ffffff;
        --muted: #d6d6d6;
        --gold: #d4af37;
        --gold-bright: #f4d03f;
        --gold-dark: #b8860b;
        --whatsapp: #25d366;
        --nav-height: 76px;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
        scroll-padding-top: var(--nav-height);
      }

      body {
        min-width: 320px;
        overflow-x: hidden;
        background:
          radial-gradient(circle at 12% 8%, rgba(212, 175, 55, 0.14), transparent 28rem),
          radial-gradient(circle at 90% 16%, rgba(244, 208, 63, 0.08), transparent 24rem),
          var(--bg);
        color: var(--text);
        font-family: Arial, Helvetica, sans-serif;
        line-height: 1.5;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .navbar {
        position: fixed;
        inset: 0 0 auto;
        z-index: 20;
        min-height: var(--nav-height);
        border-bottom: 1px solid var(--line);
        background: rgba(0, 0, 0, 0.64);
        backdrop-filter: blur(14px);
      }

      .nav-inner {
        width: min(1180px, calc(100% - 40px));
        min-height: var(--nav-height);
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 28px;
      }

      .logo-wrapper {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 0;
      }

      .logo-icon,
      .hero-icon {
        color: var(--gold);
        text-shadow: 0 0 24px rgba(212, 175, 55, 0.42);
      }

      .logo-icon {
        flex: 0 0 auto;
        font-size: 2rem;
      }

      .logo-text {
        color: var(--gold);
        font-size: 0.95rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        white-space: nowrap;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 24px;
      }

      .nav-links a {
        color: rgba(255, 255, 255, 0.86);
        font-size: 0.88rem;
        font-weight: 700;
        transition: color 0.2s ease;
      }

      .nav-links a:hover {
        color: var(--gold);
      }

      .hero {
        min-height: 96vh;
        padding: calc(var(--nav-height) + 44px) 20px 72px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        background-image:
          linear-gradient(rgba(0, 0, 0, 0.74), rgba(0, 0, 0, 0.91)),
          url("/background.jpg");
        background-position: center;
        background-size: cover;
      }

      .hero-content {
        width: min(980px, 100%);
        animation: fadeUp 0.9s ease both;
      }

      .hero-icon {
        margin-bottom: 24px;
        font-size: clamp(4.8rem, 10vw, 8rem);
        animation: floating 4s ease-in-out infinite;
      }

      .title {
        margin-bottom: 20px;
        background: linear-gradient(to right, #ffffff, var(--gold));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-size: clamp(3rem, 8vw, 5.5rem);
        font-weight: 900;
        letter-spacing: 0.06em;
        line-height: 1.05;
      }

      .subtitle {
        max-width: 680px;
        margin: 0 auto 34px;
        color: #e1e1e1;
        font-size: clamp(1rem, 2vw, 1.2rem);
        line-height: 1.8;
      }

      .button-group {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 14px;
      }

      .btn {
        min-height: 52px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        border: 0;
        border-radius: 999px;
        padding: 14px 24px;
        font: inherit;
        font-size: 0.98rem;
        font-weight: 800;
        cursor: pointer;
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease,
          border-color 0.25s ease;
      }

      .primary {
        background: linear-gradient(135deg, var(--gold), var(--gold-bright));
        color: #111111;
      }

      .secondary {
        border: 1px solid rgba(255, 255, 255, 0.18);
        background: rgba(255, 255, 255, 0.07);
        color: var(--text);
        backdrop-filter: blur(10px);
      }

      .whatsapp-btn {
        background: var(--whatsapp);
        color: var(--text);
      }

      .disabled-btn {
        border: 1px solid #777777;
        background: #5f5f5f;
        color: rgba(255, 255, 255, 0.82);
        cursor: not-allowed;
        opacity: 0.72;
      }

      .btn:hover {
        transform: translateY(-4px);
        box-shadow:
          0 0 24px rgba(212, 175, 55, 0.18),
          0 10px 28px rgba(212, 175, 55, 0.2);
      }

      .whatsapp-btn:hover {
        box-shadow:
          0 0 24px rgba(37, 211, 102, 0.28),
          0 10px 28px rgba(37, 211, 102, 0.22);
      }

      .disabled-btn:hover {
        transform: none;
        box-shadow: none;
      }

      section {
        padding: 92px 20px;
      }

      .container {
        width: min(1180px, 100%);
        margin: 0 auto;
      }

      .section-title {
        margin-bottom: 14px;
        color: var(--gold);
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1.15;
        text-align: center;
      }

      .section-title i {
        margin-right: 10px;
      }

      .section-intro {
        max-width: 680px;
        margin: 0 auto 42px;
        color: var(--muted);
        font-size: 1.03rem;
        line-height: 1.8;
        text-align: center;
      }

      .about-grid,
      .action-grid,
      .location-panel,
      .prize-grid {
        display: grid;
        gap: 22px;
      }

      .about-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .action-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .prize-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        align-items: start;
      }

      .location-panel {
        grid-template-columns: minmax(280px, 0.8fr) minmax(0, 1.2fr);
        overflow: hidden;
        border-radius: 22px;
      }

      .about-card,
      .action-card,
      .location-panel,
      .prize-card,
      .results-box {
        border: 1px solid var(--line);
        background: linear-gradient(145deg, var(--panel), var(--panel-soft));
        backdrop-filter: blur(10px);
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.16);
      }

      .about-card,
      .action-card {
        border-radius: 18px;
        padding: 32px 28px;
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease;
      }

      .about-card {
        min-height: 220px;
        text-align: center;
      }

      .about-card:hover,
      .action-card:hover,
      .prize-card:hover {
        transform: translateY(-6px);
        box-shadow:
          0 0 24px rgba(212, 175, 55, 0.11),
          0 14px 34px rgba(212, 175, 55, 0.15);
      }

      .about-icon,
      .action-icon,
      .results-icon {
        color: var(--gold);
        font-size: 2.45rem;
      }

      .about-icon {
        margin-bottom: 18px;
      }

      .action-icon {
        margin-bottom: 22px;
      }

      .about-card h3,
      .action-card h3 {
        margin-bottom: 10px;
        font-size: 1.32rem;
      }

      .about-card p,
      .action-card p,
      .results-box p {
        color: var(--muted);
        line-height: 1.75;
      }

      .action-card p {
        min-height: 78px;
        margin-bottom: 22px;
      }

      .action-card .btn {
        width: 100%;
      }

      .venue-actions,
      .location-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .venue-actions {
        justify-content: center;
        margin-top: 18px;
      }

      .mini-link {
        min-height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 999px;
        padding: 9px 13px;
        background: rgba(255, 255, 255, 0.07);
        color: var(--text);
        font-size: 0.84rem;
        font-weight: 800;
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease;
      }

      .mini-link:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 24px rgba(212, 175, 55, 0.14);
      }

      .map-link {
        border-color: rgba(212, 175, 55, 0.36);
      }

      .waze-link {
        border-color: rgba(51, 204, 255, 0.36);
      }

      .location-copy {
        padding: 38px;
      }

      .location-copy h3 {
        margin-bottom: 12px;
        color: var(--gold);
        font-size: 1.6rem;
      }

      .location-copy p {
        margin-bottom: 22px;
        color: var(--muted);
        line-height: 1.75;
      }

      .map-preview {
        min-height: 360px;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.04);
      }

      .map-preview iframe {
        display: block;
        width: 100%;
        height: 100%;
        min-height: 360px;
        border: 0;
      }

      .table-wrapper {
        width: 100%;
        overflow-x: auto;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.025);
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th,
      td {
        padding: 16px 18px;
        text-align: left;
        vertical-align: middle;
      }

      th {
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        color: #111111;
        font-size: 0.9rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      td {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        color: #e6e6e6;
      }

      tr:hover td {
        background: rgba(255, 255, 255, 0.035);
      }

      .flow-table th:last-child,
      .flow-table td:last-child {
        width: 38%;
      }

      .prize-card {
        overflow: hidden;
        border-radius: 18px;
        padding: 26px;
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease;
      }

      .prize-title {
        margin-bottom: 18px;
        color: var(--gold);
        font-size: 1.45rem;
        text-align: center;
      }

      .prize-card .table-wrapper {
        border-radius: 14px;
      }

      .results-box {
        max-width: 760px;
        margin: 0 auto;
        border-radius: 22px;
        padding: 50px 30px;
        text-align: center;
      }

      .results-icon {
        margin-bottom: 18px;
      }

      .results-box h3 {
        margin-bottom: 14px;
        color: var(--gold);
        font-size: clamp(1.7rem, 3vw, 2.15rem);
      }

      .results-box p {
        max-width: 480px;
        margin: 0 auto 28px;
      }

      footer {
        border-top: 1px solid var(--line);
        padding: 32px 20px;
        color: #929292;
        text-align: center;
      }

      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(28px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes floating {
        0%,
        100% {
          transform: translateY(0);
        }

        50% {
          transform: translateY(-12px);
        }
      }

      @media (max-width: 980px) {
        .nav-links {
          display: none;
        }

        .about-grid,
        .action-grid,
        .location-panel,
        .prize-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 640px) {
        :root {
          --nav-height: 68px;
        }

        .nav-inner {
          width: min(100% - 28px, 1180px);
        }

        .logo-icon {
          font-size: 1.75rem;
        }

        .logo-text {
          font-size: 0.78rem;
          letter-spacing: 0.08em;
          white-space: normal;
        }

        .hero {
          min-height: 100svh;
          padding: calc(var(--nav-height) + 34px) 16px 52px;
        }

        .title {
          letter-spacing: 0.035em;
        }

        .hero .btn,
        .button-group .btn {
          width: 100%;
          max-width: 360px;
        }

        section {
          padding: 72px 16px;
        }

        .section-intro {
          margin-bottom: 30px;
        }

        .about-card,
        .action-card,
        .location-panel,
        .prize-card,
        .results-box {
          border-radius: 16px;
        }

        .prize-card {
          padding: 18px;
        }

        .location-copy {
          padding: 26px;
        }

        .location-actions .btn {
          width: 100%;
        }

        table {
          min-width: 540px;
        }

        th,
        td {
          padding: 14px;
        }
      }
    </style>
  </head>

  <body>
    <nav class="navbar">
      <div class="nav-inner">
        <a class="logo-wrapper" href="#top" aria-label="KH Chess Championship home">
          <span class="logo-icon" aria-hidden="true">
            <i class="fa-solid fa-chess-king"></i>
          </span>
          <span class="logo-text">KH CHESS CHAMPIONSHIP</span>
        </a>

        <div class="nav-links" aria-label="Main navigation">
          <a href="#about">ABOUT</a>
          <a href="#location">LOCATION</a>
          <a href="#registration">REGISTER</a>
          <a href="#resources">RESOURCES</a>
          <a href="#flow">FLOW</a>
          <a href="#prizes">PRIZES</a>
          <a href="#results">RESULTS</a>
        </div>
      </div>
    </nav>

    <main id="top">
      <section class="hero">
        <div class="hero-content">
          <div class="hero-icon" aria-hidden="true">
            <i class="fa-solid fa-chess-king"></i>
          </div>

          <h1 class="title">
            KH CHESS<br />
            CHAMPIONSHIP 2026
          </h1>

          <div class="button-group">
            <a
              class="btn primary"
              href="https://docs.google.com/forms/d/e/1FAIpQLSe_pei4kRKKpWDWcyWBWajBtfvKMD0aJGTz90Sb4XgfWBbNEA/viewform?usp=dialog"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-solid fa-user-plus"></i>
              Register Now
            </a>
          </div>
        </div>
      </section>

      <section id="about">
        <div class="container">
          <h2 class="section-title">
            <i class="fa-solid fa-chess-king"></i>
            About The Tournament
          </h2>
          <p class="section-intro">
            Key tournament details are gathered here.
          </p>

          <div class="about-grid">
            <article class="about-card">
              <div class="about-icon" aria-hidden="true">
                <i class="fa-solid fa-calendar-days"></i>
              </div>
              <h3>Date</h3>
              <p>
                27th June 2026<br />
                Saturday
              </p>
            </article>

            <article class="about-card">
              <div class="about-icon" aria-hidden="true">
                <i class="fa-solid fa-clock"></i>
              </div>
              <h3>Time</h3>
              <p>08:00 a.m. - 06:00 p.m.</p>
            </article>

            <article class="about-card">
              <div class="about-icon" aria-hidden="true">
                <i class="fa-solid fa-location-dot"></i>
              </div>
              <h3>Venue</h3>
              <p>Dewan Dato Teoh Boon Beng</p>
              <div class="venue-actions" aria-label="Venue navigation links">
                <a
                  class="mini-link map-link"
                  href="https://maps.app.goo.gl/C7Jh2wSXNGhWFsme7"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <i class="fa-solid fa-map-location-dot"></i>
                  Google Maps
                </a>
                <a
                  class="mini-link waze-link"
                  href="https://ul.waze.com/ul?venue_id=65798205.657719905.580731&overview=yes&utm_campaign=default&utm_source=waze_website&utm_medium=lm_share_location"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <i class="fa-brands fa-waze"></i>
                  Waze
                </a>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section id="location">
        <div class="container">
          <h2 class="section-title">
            <i class="fa-solid fa-map-location-dot"></i>
            Location
          </h2>
          <p class="section-intro">
            Preview the venue map here, then open your preferred navigation app for directions.
          </p>

          <div class="location-panel">
            <div class="location-copy">
              <h3>Dewan Dato Teoh Boon Beng</h3>
              <p>
                Use Google Maps for a full map view or Waze for live driving navigation to the tournament venue.
              </p>
              <div class="location-actions">
                <a
                  class="btn primary"
                  href="https://maps.app.goo.gl/C7Jh2wSXNGhWFsme7"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <i class="fa-solid fa-map-location-dot"></i>
                  Open Google Maps
                </a>
                <a
                  class="btn secondary"
                  href="https://ul.waze.com/ul?venue_id=65798205.657719905.580731&overview=yes&utm_campaign=default&utm_source=waze_website&utm_medium=lm_share_location"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <i class="fa-brands fa-waze"></i>
                  Open Waze
                </a>
              </div>
            </div>

            <div class="map-preview">
              <iframe
                title="Map preview for Dewan Dato Teoh Boon Beng"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                src="https://www.google.com/maps?q=Dewan%20Dato%20Teoh%20Boon%20Beng&output=embed"
              ></iframe>
            </div>
          </div>
        </div>
      </section>

      <section id="registration">
        <div class="container">
          <h2 class="section-title">
            <i class="fa-solid fa-user-check"></i>
            Registration & Updates
          </h2>
          <p class="section-intro">
            Register, confirm your entry, and join the official WhatsApp group from this section.
          </p>

          <div class="action-grid">
            <article class="action-card">
              <div class="action-icon" aria-hidden="true">
                <i class="fa-solid fa-user-plus"></i>
              </div>
              <h3>Player Registration</h3>
              <p>Submit your details through the official registration form.</p>
              <a
                class="btn primary"
                href="https://docs.google.com/forms/d/e/1FAIpQLSe_pei4kRKKpWDWcyWBWajBtfvKMD0aJGTz90Sb4XgfWBbNEA/viewform?usp=dialog"
                target="_blank"
                rel="noopener noreferrer"
              >
                Register Now
              </a>
            </article>

            <article class="action-card">
              <div class="action-icon" aria-hidden="true">
                <i class="fa-solid fa-magnifying-glass"></i>
              </div>
              <h3>Registration Check</h3>
              <p>Already registered? Check whether your name is listed correctly.</p>
              <a
                class="btn secondary"
                href="https://docs.google.com/spreadsheets/d/17StExfw3ixo0GBAnwzGDHZYlYMtwwRM4HYjtrxuEeJE/edit?usp=sharing"
                target="_blank"
                rel="noopener noreferrer"
              >
                Check Registration
              </a>
            </article>

            <article class="action-card">
              <div class="action-icon" aria-hidden="true">
                <i class="fa-brands fa-whatsapp"></i>
              </div>
              <h3>WhatsApp Group</h3>
              <p>Join the tournament group for announcements and quick updates.</p>
              <a
                class="btn whatsapp-btn"
                href="https://chat.whatsapp.com/Hh2yKVw47mcCkCIzHq8rjl?mode=gi_t"
                target="_blank"
                rel="noopener noreferrer"
              >
                Join Group
              </a>
            </article>
          </div>
        </div>
      </section>

      <section id="resources">
        <div class="container">
          <h2 class="section-title">
            <i class="fa-solid fa-book"></i>
            Tournament Resources
          </h2>
          <p class="section-intro">
            You can find rules and services here.
          </p>

          <div class="action-grid">
            <article class="action-card">
              <div class="action-icon" aria-hidden="true">
                <i class="fa-solid fa-book"></i>
              </div>
              <h3>Tournament Rules</h3>
              <p>Read the full rules document before the event day.</p>
              <a
                class="btn secondary"
                href="https://docs.google.com/document/d/1j6rJqnWfSFP7mva4H-6OMYipO1QGAL9FcfVosqkd_eE/edit?usp=sharing"
                target="_blank"
                rel="noopener noreferrer"
              >
                View Rules
              </a>
            </article>

            <article class="action-card">
              <div class="action-icon" aria-hidden="true">
                <i class="fa-solid fa-utensils"></i>
              </div>
              <h3>Food Order</h3>
              <p>Food ordering will be available here once the order form is ready.</p>
              <button class="btn disabled-btn" type="button" disabled>
                Coming Soon
              </button>
            </article>

            <article class="action-card">
              <div class="action-icon" aria-hidden="true">
                <i class="fa-solid fa-circle-info"></i>
              </div>
              <h3>Event Information</h3>
              <p>Use the tournament flow and prize sections below for schedule and award details.</p>
              <a class="btn secondary" href="#flow">
                View Flow
              </a>
            </article>
          </div>
        </div>
      </section>

      <section id="flow">
        <div class="container">
          <h2 class="section-title">
            <i class="fa-solid fa-chess-board"></i>
            Tentative Flow
          </h2>
          <p class="section-intro">
            The schedule below is tentative and may be adjusted by the organizer.
          </p>

          <div class="table-wrapper">
            <table class="flow-table">
              <thead>
                <tr>
                  <th>Event</th>
                  <th>Time</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>Registration</td><td>08:00 a.m.</td></tr>
